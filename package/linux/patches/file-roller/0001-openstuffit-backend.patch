+#include <config.h>
+#include <time.h>
+#include <glib.h>
+#include <glib/gi18n.h>
+#include <json-glib/json-glib.h>
+#include "fr-file-data.h"
+#include "file-utils.h"
+#include "gio-utils.h"
+#include "glib-utils.h"
+#include "fr-command.h"
+#include "fr-command-openstuffit.h"
+#include "fr-error.h"
+
+#define OPENSTUFFIT_BRIDGE_DEFAULT "/usr/bin/openstuffit-fr-bridge"
+#define OPENSTUFFIT_BRIDGE_ENV "OPENSTUFFIT_FR_BRIDGE"
+
+struct _FrCommandOpenstuffit
+{
+	FrCommand     parent_instance;
+	GInputStream *stream;
+};
+
+G_DEFINE_TYPE (FrCommandOpenstuffit, fr_command_openstuffit, fr_command_get_type ())
+
+static const char *
+openstuffit_bridge_program (void)
+{
+	const char *env_path;
+
+	env_path = g_getenv (OPENSTUFFIT_BRIDGE_ENV);
+	if ((env_path != NULL) && (env_path[0] != '\0'))
+		return env_path;
+	if (g_file_test (OPENSTUFFIT_BRIDGE_DEFAULT, G_FILE_TEST_IS_EXECUTABLE))
+		return OPENSTUFFIT_BRIDGE_DEFAULT;
+	return "openstuffit-fr-bridge";
+}
+
+static gboolean
+openstuffit_bridge_available (gboolean check_command)
+{
+	const char *env_path;
+
+	env_path = g_getenv (OPENSTUFFIT_BRIDGE_ENV);
+	if ((env_path != NULL) && (env_path[0] != '\0'))
+		return ! check_command || g_file_test (env_path, G_FILE_TEST_IS_EXECUTABLE);
+
+	if (g_file_test (OPENSTUFFIT_BRIDGE_DEFAULT, G_FILE_TEST_IS_EXECUTABLE))
+		return TRUE;
+
+	return _g_program_is_available ("openstuffit-fr-bridge", check_command);
+}
+
+static void
+process_line (char     *line,
+	      gpointer  data)
+{
+	FrCommandOpenstuffit *self = FR_COMMAND_OPENSTUFFIT (data);
+
+	g_memory_input_stream_add_data (G_MEMORY_INPUT_STREAM (self->stream), line, -1, NULL);
+}
+
+static void
+list_command_completed (gpointer data)
+{
+	FrCommandOpenstuffit *self = FR_COMMAND_OPENSTUFFIT (data);
+	JsonParser           *parser;
+	GError               *error = NULL;
+
+	parser = json_parser_new ();
+	if (json_parser_load_from_stream (parser, self->stream, NULL, &error)) {
+		JsonObject *root;
+		JsonArray  *entries;
+
+		root = json_node_get_object (json_parser_get_root (parser));
+		if (! json_object_has_member (root, "entries")) {
+			g_object_unref (parser);
+			return;
+		}
+
+		entries = json_object_get_array_member (root, "entries");
+		for (guint i = 0; i < json_array_get_length (entries); i++) {
+			JsonObject *entry;
+			FrFileData *fdata;
+			const char *path;
+			gint64      mtime_unix = 0;
+
+			entry = json_array_get_object_element (entries, i);
+			path = json_object_get_string_member (entry, "path");
+			if ((path == NULL) || (path[0] == '\0'))
+				continue;
+
+			fdata = fr_file_data_new ();
+			fdata->size = json_object_get_int_member (entry, "size");
+			if (json_object_has_member (entry, "mtime_unix"))
+				mtime_unix = json_object_get_int_member (entry, "mtime_unix");
+			fdata->modified = (time_t) mtime_unix;
+			fdata->encrypted = json_object_has_member (entry, "encrypted") ? json_object_get_boolean_member (entry, "encrypted") : FALSE;
+			fdata->dir = json_object_has_member (entry, "is_dir") ? json_object_get_boolean_member (entry, "is_dir") : FALSE;
+
+			if (path[0] == '/') {
+				fdata->full_path = g_strdup (path);
+				fdata->original_path = fdata->full_path;
+			}
+			else {
+				fdata->full_path = g_strconcat ("/", path, NULL);
+				fdata->original_path = fdata->full_path + 1;
+			}
+
+			fdata->link = NULL;
+			if (fdata->dir)
+				fdata->name = _g_path_get_dir_name (fdata->full_path);
+			else
+				fdata->name = g_strdup (_g_path_get_basename (fdata->full_path));
+			fdata->path = _g_path_remove_level (fdata->full_path);
+
+			fr_archive_add_file (FR_ARCHIVE (self), fdata);
+		}
+	}
+
+	g_clear_error (&error);
+	g_object_unref (parser);
+}
+
+static gboolean
+fr_command_openstuffit_list (FrCommand *comm)
+{
+	FrCommandOpenstuffit *self = FR_COMMAND_OPENSTUFFIT (comm);
+
+	_g_object_unref (self->stream);
+	self->stream = g_memory_input_stream_new ();
+
+	fr_process_set_out_line_func (comm->process, process_line, comm);
+	fr_process_begin_command (comm->process, openstuffit_bridge_program ());
+	fr_process_set_end_func (comm->process, list_command_completed, comm);
+	fr_process_add_arg (comm->process, "list");
+	fr_process_add_arg (comm->process, "--json");
+	fr_process_add_arg (comm->process, "--unicode-normalization");
+	fr_process_add_arg (comm->process, "nfc");
+	if ((FR_ARCHIVE (comm)->password != NULL) && (FR_ARCHIVE (comm)->password[0] != '\0')) {
+		fr_process_add_arg (comm->process, "--password");
+		fr_process_add_arg (comm->process, FR_ARCHIVE (comm)->password);
+	}
+	fr_process_add_arg (comm->process, comm->filename);
+	fr_process_end_command (comm->process);
+
+	return TRUE;
+}
+
+static void
+fr_command_openstuffit_extract (FrCommand  *comm,
+				const char *from_file,
+				GList      *file_list,
+				const char *dest_dir,
+				gboolean    overwrite,
+				gboolean    skip_older,
+				gboolean    junk_paths)
+{
+	GList *scan;
+	(void) skip_older;
+	(void) junk_paths;
+
+	fr_process_use_standard_locale (comm->process, TRUE);
+	fr_process_begin_command (comm->process, openstuffit_bridge_program ());
+	fr_process_add_arg (comm->process, "extract");
+	if (dest_dir != NULL) {
+		fr_process_add_arg (comm->process, "--output-dir");
+		fr_process_add_arg (comm->process, dest_dir);
+	}
+	if (overwrite)
+		fr_process_add_arg (comm->process, "--overwrite");
+	else
+		fr_process_add_arg (comm->process, "--skip-existing");
+	fr_process_add_arg (comm->process, "--unicode-normalization");
+	fr_process_add_arg (comm->process, "nfc");
+	if ((FR_ARCHIVE (comm)->password != NULL) && (FR_ARCHIVE (comm)->password[0] != '\0')) {
+		fr_process_add_arg (comm->process, "--password");
+		fr_process_add_arg (comm->process, FR_ARCHIVE (comm)->password);
+	}
+	if ((from_file != NULL) && (from_file[0] != '\0')) {
+		const char *entry = from_file;
+		while (entry[0] == '/')
+			entry++;
+		if (entry[0] != '\0') {
+			fr_process_add_arg (comm->process, "--entry");
+			fr_process_add_arg (comm->process, entry);
+		}
+	}
+	else {
+		for (scan = file_list; scan != NULL; scan = scan->next) {
+			const char *entry = scan->data;
+
+			if (entry == NULL)
+				continue;
+			while (entry[0] == '/')
+				entry++;
+			if (entry[0] == '\0')
+				continue;
+			fr_process_add_arg (comm->process, "--entry");
+			fr_process_add_arg (comm->process, entry);
+		}
+	}
+	fr_process_add_arg (comm->process, comm->filename);
+	fr_process_end_command (comm->process);
+}
+
+static void
+fr_command_openstuffit_handle_error (FrCommand *comm,
+				     FrError   *error)
+{
+	(void) comm;
+
+	if (error->type == FR_ERROR_NONE)
+		return;
+
+	if (error->status == 4)
+		fr_error_take_gerror (error, g_error_new_literal (FR_ERROR, FR_ERROR_ASK_PASSWORD, ""));
+	else if (error->status == 2)
+		fr_error_take_gerror (error, g_error_new_literal (FR_ERROR, FR_ERROR_UNSUPPORTED_FORMAT, ""));
+}
+
+static const char *openstuffit_mime_type[] = { "application/x-stuffit", NULL };
+
+static const char **
+fr_command_openstuffit_get_mime_types (FrArchive *archive)
+{
+	(void) archive;
+	return openstuffit_mime_type;
+}
+
+static FrArchiveCaps
+fr_command_openstuffit_get_capabilities (FrArchive  *archive,
+					 const char *mime_type,
+					 gboolean    check_command)
+{
+	FrArchiveCaps capabilities;
+
+	(void) archive;
+	(void) mime_type;
+
+	capabilities = FR_ARCHIVE_CAN_DO_NOTHING;
+	if (openstuffit_bridge_available (check_command))
+		capabilities |= FR_ARCHIVE_CAN_READ;
+
+	return capabilities;
+}
+
+static const char *
+fr_command_openstuffit_get_packages (FrArchive  *archive,
+				     const char *mime_type)
+{
+	(void) archive;
+	(void) mime_type;
+	return FR_PACKAGES ("openstuffit");
+}
+
+static void
+fr_command_openstuffit_finalize (GObject *object)
+{
+	FrCommandOpenstuffit *self;
+
+	g_return_if_fail (object != NULL);
+	g_return_if_fail (FR_IS_COMMAND_OPENSTUFFIT (object));
+
+	self = FR_COMMAND_OPENSTUFFIT (object);
+	_g_object_unref (self->stream);
+
+	if (G_OBJECT_CLASS (fr_command_openstuffit_parent_class)->finalize != NULL)
+		G_OBJECT_CLASS (fr_command_openstuffit_parent_class)->finalize (object);
+}
+
+static void
+fr_command_openstuffit_class_init (FrCommandOpenstuffitClass *klass)
+{
+	GObjectClass   *gobject_class;
+	FrArchiveClass *archive_class;
+	FrCommandClass *command_class;
+
+	fr_command_openstuffit_parent_class = g_type_class_peek_parent (klass);
+
+	gobject_class = G_OBJECT_CLASS (klass);
+	gobject_class->finalize = fr_command_openstuffit_finalize;
+
+	archive_class = FR_ARCHIVE_CLASS (klass);
+	archive_class->get_mime_types = fr_command_openstuffit_get_mime_types;
+	archive_class->get_capabilities = fr_command_openstuffit_get_capabilities;
+	archive_class->get_packages = fr_command_openstuffit_get_packages;
+
+	command_class = FR_COMMAND_CLASS (klass);
+	command_class->list = fr_command_openstuffit_list;
+	command_class->extract = fr_command_openstuffit_extract;
+	command_class->handle_error = fr_command_openstuffit_handle_error;
+}
+
+static void
+fr_command_openstuffit_init (FrCommandOpenstuffit *self)
+{
+	FrArchive *base = FR_ARCHIVE (self);
+
+	base->propExtractCanAvoidOverwrite = TRUE;
+	base->propExtractCanSkipOlder = FALSE;
+	base->propExtractCanJunkPaths = FALSE;
+	base->propPassword = TRUE;
+	base->propTest = FALSE;
+	base->propListFromFile = FALSE;
+
+	self->stream = NULL;
+}
